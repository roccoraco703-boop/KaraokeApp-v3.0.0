<Window x:Class="KaraokeApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:KaraokeApp.Controls"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="KaraokeApp"
        Height="760"
        Width="1180"
        MinHeight="680"
        MinWidth="1050"
        Background="#070B16">

    <Window.Resources>
        <LinearGradientBrush x:Key="DesktopBg" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0E7490" Offset="0"/>
            <GradientStop Color="#0F4C63" Offset="0.55"/>
            <GradientStop Color="#082F49" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="PanelChrome" StartPoint="0,0" EndPoint="0,1">
            <GradientStop Color="#DBF4FF" Offset="0"/>
            <GradientStop Color="#7DD3FC" Offset="0.35"/>
            <GradientStop Color="#0F172A" Offset="1"/>
        </LinearGradientBrush>
        <Style x:Key="VanPanel" TargetType="Border">
            <Setter Property="BorderBrush" Value="#BAE6FD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Background" Value="#0F172A"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="#020617" BlurRadius="14" ShadowDepth="5" Opacity="0.45"/>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#1E40AF"/>
            <Setter Property="Foreground" Value="#E0F2FE"/>
            <Setter Property="BorderBrush" Value="#7DD3FC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="4,2"/>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Foreground" Value="#38BDF8"/>
            <Setter Property="Background" Value="#020617"/>
        </Style>

        <!-- Lyrics styles (VanBasco-like) -->
        <DropShadowEffect x:Key="LyricGlowEffect" Color="Gold" BlurRadius="36" ShadowDepth="0" Opacity="0.96"/>

        <Style x:Key="PreviousLyricStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#38BDF8"/>
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8"/>
        </Style>

        <Style x:Key="NextLyricStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C0C0C0"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Margin" Value="8"/>
        </Style>

        <Style x:Key="CurrentLyricWordStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="88"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="6,0"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsHighlighted}" Value="True">
                    <Setter Property="Foreground" Value="#22C55E"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter Property="Foreground" Value="#FFD700"/>
                    <Setter Property="Effect" Value="{StaticResource LyricGlowEffect}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Background="{StaticResource DesktopBg}" Margin="18">
        <Canvas ClipToBounds="False">
            <controls:FloatingPanel x:Name="LyricsPanel" Title="Benvenuti in KaraokeApp Player" Width="690" Height="260" Canvas.Left="58" Canvas.Top="34" MinWidth="420" MinHeight="170" Opacity="0.95">
                <Grid Background="Black" ClipToBounds="True">

                    <Border BorderBrush="#0EA5E9" BorderThickness="1" Margin="8"/>

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Riga precedente -->
                        <TextBlock Grid.Row="0"
                                   Text="{Binding PlayerVM.TopLine}"
                                   Style="{StaticResource PreviousLyricStyle}"/>

                        <!-- Riga corrente karaoke (auto-zoom con Viewbox) -->
                        <Viewbox Grid.Row="1" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center" MaxHeight="220">
                            <ItemsControl ItemsSource="{Binding PlayerVM.CurrentLineWords}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}" Style="{StaticResource CurrentLyricWordStyle}"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Viewbox>

                        <!-- Riga successiva -->
                        <TextBlock Grid.Row="2" Text="{Binding PlayerVM.NextPhrase}" Style="{StaticResource NextLyricStyle}"/>
                    </Grid>
                </Grid>
            </controls:FloatingPanel>

            <controls:FloatingPanel Title="SYNC" Width="155" Height="220" Canvas.Left="860" Canvas.Top="530" MinWidth="145" MinHeight="180">
                <GroupBox Header="Sync" Padding="6">
                    <StackPanel>
                        <TextBlock Text="Lyrics Offset"/>
                        <Slider Minimum="-5000" Maximum="5000" Value="{Binding LyricsOffsetMs, Mode=TwoWay}"/>
                        <TextBlock Text="MIDI Offset"/>
                        <Slider Minimum="-5000" Maximum="5000" Value="{Binding MidiOffsetMs, Mode=TwoWay}"/>
                        <TextBlock Text="Video Offset"/>
                        <Slider Minimum="-5000" Maximum="5000" Value="{Binding VideoOffsetMs, Mode=TwoWay}"/>
                    </StackPanel>
                </GroupBox>
            </controls:FloatingPanel>

            <controls:FloatingPanel Title="KARAOKE PLAYER" Width="330" Height="158" Canvas.Left="790" Canvas.Top="35" MinWidth="280" MinHeight="135">
                <StackPanel Margin="12,8">
                    <Border Background="Black" BorderBrush="#7DD3FC" BorderThickness="1" Height="24">
                        <TextBlock Text="{Binding SelectedSong.Title, TargetNullValue=Nessun brano}" Foreground="#F87171" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="13"/>
                    </Border>
                    <Border Background="#020617" BorderBrush="#38BDF8" BorderThickness="1" Height="36" Margin="0,8,0,6">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <TextBlock Text="{Binding PlayerVM.CurrentTime, StringFormat={}{0:000000}}" Foreground="#22D3EE" FontSize="18" FontWeight="Bold" Margin="0,0,12,0"/>
                            <TextBlock Text="{Binding PlayerVM.Score, StringFormat=SCORE {0}}" Foreground="#22C55E" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <Button Content="&lt;&lt;" Command="{Binding PreviousSongCommand}" Width="42" Height="24" Margin="2"/>
                        <Button Content="PLAY" Command="{Binding StartCommand}" Width="62" Height="24" Margin="2"/>
                        <Button Content="STOP" Command="{Binding StopCommand}" Width="56" Height="24" Margin="2"/>
                        <Button Content="&gt;&gt;" Command="{Binding NextSongCommand}" Width="42" Height="24" Margin="2"/>
                        <Button Content="RST" Command="{Binding ResetScoreCommand}" Width="42" Height="24" Margin="2"/>
                    </StackPanel>
                </StackPanel>
            </controls:FloatingPanel>

            <controls:FloatingPanel Title="PIANO - TONALITÀ VOCE" Width="625" Height="95" Canvas.Left="270" Canvas.Top="350" MinWidth="420" MinHeight="80">
                <Grid Margin="8,5">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="{Binding VoiceKeyShiftText}" Foreground="#BAE6FD" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <UniformGrid Grid.Row="1" Columns="5" Margin="0,4,0,0">
                        <Button Content="- TONO" Command="{Binding DecreaseVoiceToneCommand}" Background="White" Foreground="#0F172A" BorderBrush="#111827" Margin="2"/>
                        <Button Content="- SEMI" Command="{Binding DecreaseVoiceSemitoneCommand}" Background="#111827" Foreground="White" BorderBrush="#334155" Margin="2"/>
                        <Button Content="RESET" Command="{Binding ResetVoiceKeyCommand}" Background="#0EA5E9" Foreground="White" BorderBrush="#7DD3FC" Margin="2"/>
                        <Button Content="+ SEMI" Command="{Binding IncreaseVoiceSemitoneCommand}" Background="#111827" Foreground="White" BorderBrush="#334155" Margin="2"/>
                        <Button Content="+ TONO" Command="{Binding IncreaseVoiceToneCommand}" Background="White" Foreground="#0F172A" BorderBrush="#111827" Margin="2"/>
                    </UniformGrid>
                </Grid>
            </controls:FloatingPanel>

            <controls:FloatingPanel Title="PIANO ROLL" Width="620" Height="240" Canvas.Left="330" Canvas.Top="470" MinWidth="360" MinHeight="140">
                <Grid Background="#020617" Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <ListBox Grid.Column="0" ItemsSource="{Binding MidiChannels}" Margin="0,0,8,0" Background="#020617" BorderBrush="#334155" Foreground="#7DD3FC" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}" FontSize="9" TextTrimming="CharacterEllipsis"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Grid Grid.Column="1">
                        <Grid Opacity="0.15">

                            <Grid.RowDefinitions>

                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>
                                <RowDefinition/>

                            </Grid.RowDefinitions>

                            <Rectangle Grid.Row="0" Fill="#38BDF8"/>
                            <Rectangle Grid.Row="1" Fill="#1E293B"/>
                            <Rectangle Grid.Row="2" Fill="#38BDF8"/>
                            <Rectangle Grid.Row="3" Fill="#1E293B"/>
                            <Rectangle Grid.Row="4" Fill="#38BDF8"/>
                            <Rectangle Grid.Row="5" Fill="#1E293B"/>
                            <Rectangle Grid.Row="6" Fill="#38BDF8"/>
                            <Rectangle Grid.Row="7" Fill="#1E293B"/>
                            <Rectangle Grid.Row="8" Fill="#38BDF8"/>
                            <Rectangle Grid.Row="9" Fill="#1E293B"/>

                        </Grid>
                        <controls:KaraokePitchCanvas x:Name="PitchCanvas" Notes="{Binding PlayerVM.PitchNotes}" CurrentTime="{Binding PlayerVM.CurrentTime}" CurrentPitch="{Binding PlayerVM.CurrentPitch}"/>

                        <Border VerticalAlignment="Top" HorizontalAlignment="Left" Margin="8" Background="#0F172A" Opacity="0.85" CornerRadius="6">
                            <StackPanel Orientation="Horizontal" Margin="6">
                                <CheckBox Content="Snap to Note" IsChecked="{Binding ElementName=PitchCanvas, Path=SnapToActiveNote, Mode=TwoWay}" Foreground="#E0F2FE" Margin="0,0,8,0"/>
                                <CheckBox Content="Follow Playback" IsChecked="{Binding ElementName=PitchCanvas, Path=FollowPlayback, Mode=TwoWay}" Foreground="#E0F2FE" Margin="0,0,8,0"/>
                                <TextBlock Text="Zoom" Foreground="#E0F2FE" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <Slider Width="120" Minimum="20" Maximum="400" Value="{Binding ElementName=PitchCanvas, Path=PixelsPerSecond, Mode=TwoWay}" />
                                <TextBlock Text="{Binding ElementName=PitchCanvas, Path=PixelsPerSecond, StringFormat={}{0:0} px/s}" Foreground="#E0F2FE" VerticalAlignment="Center" Margin="6,0,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </controls:FloatingPanel>

            <controls:FloatingPanel Title="CONTROL" Width="155" Height="220" Canvas.Left="860" Canvas.Top="300" MinWidth="145" MinHeight="180">
                <StackPanel Margin="12">
                    <TextBlock Text="{Binding PlayerVM.Rank}" Foreground="#38BDF8" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding PlayerVM.Combo, StringFormat=COMBO {0}}" Foreground="#22C55E" FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,8"/>
                    <TextBlock Text="MIC" Foreground="#BAE6FD" FontSize="10"/>
                    <Slider Minimum="0" Maximum="2" Value="{Binding MicVolume}" Margin="0,0,0,8"/>
                    <TextBlock Text="MUSIC" Foreground="#BAE6FD" FontSize="10"/>
                    <Slider Minimum="0" Maximum="2" Value="{Binding MusicVolume}" Margin="0,0,0,8"/>
                    <Button Content="MIC" Command="{Binding TestMicrophoneCommand}" Height="24" Margin="0,0,0,4"/>
                    <Button Content="{Binding MixerStatus}" Command="{Binding ToggleMixerCommand}" Height="24" Margin="0,0,0,4"/>
                    <Button Content="{Binding MonitorStatus}" Command="{Binding ToggleMicrophoneMuteCommand}" Height="24"/>
                </StackPanel>
            </controls:FloatingPanel>

            <controls:FloatingPanel Title="PLAYLIST" Width="260" Height="500" Canvas.Left="18" Canvas.Top="500" MinWidth="210" MinHeight="135" Visibility="Collapsed">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60*"/>
                        <ColumnDefinition Width="61*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Grid.ColumnSpan="2">

                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,6">
                            <Button Content="📂 Libreria" Command="{Binding SelectLibraryFolderCommand}" Width="110" Height="24" Margin="0,0,8,0"/>
                            <Button Content="🔄 Aggiorna" Command="{Binding RefreshLibraryCommand}" Width="90" Height="24"/>
                        </StackPanel>

                        <TextBox
                                Margin="0,0,0,4"
                                Text="{Binding Library.SearchText,
                                              UpdateSourceTrigger=PropertyChanged}"
                                ToolTip="Cerca titolo o artista"/>

                        <CheckBox
                                Content="Solo Preferiti"
                                IsChecked="{Binding Library.ShowFavoritesOnly}"
                                Foreground="#E0F2FE"/>

                    </StackPanel>
                    <TabControl
                                    Background="#020617" Grid.ColumnSpan="2" Margin="0,36,0,0" Grid.RowSpan="2">

                        <TabItem Header="Library">

                            <ListBox
                                    ItemsSource="{Binding Library.Songs}"
                                    SelectedItem="{Binding Library.SelectedSong}"
                                    Background="#020617"
                                    BorderBrush="#334155"
                                    Foreground="#E0F2FE">



                                <ListBox.ItemTemplate>

                                    <DataTemplate>

                                        <StackPanel>

                                            <TextBlock
                            Text="{Binding DisplayName}"
                            FontWeight="Bold"/>

                                            <TextBlock
                            Text="{Binding Status}"
                            FontSize="10"
                            Foreground="#94A3B8"/>

                                        </StackPanel>

                                    </DataTemplate>

                                </ListBox.ItemTemplate>

                            </ListBox>

                        </TabItem>

                        <TabItem Header="Recent">

                            <ListBox
                                    ItemsSource="{Binding Library.RecentSongs}"
                                    SelectedItem="{Binding Library.SelectedSong}"
                                    Background="#020617"
                                    BorderBrush="#334155"
                                    Foreground="#E0F2FE">

                                <ListBox.ItemTemplate>

                                    <DataTemplate>

                                        <StackPanel>

                                            <TextBlock
                        Text="{Binding DisplayName}"
                        FontWeight="Bold"/>

                                            <TextBlock
                        Text="{Binding Status}"
                        FontSize="10"
                        Foreground="#94A3B8"/>

                                        </StackPanel>

                                    </DataTemplate>

                                </ListBox.ItemTemplate>

                            </ListBox>

                        </TabItem>

                        <TabItem Header="Top">

                            <ListBox
                                    ItemsSource="{Binding Library.TopSongs}"
                                    SelectedItem="{Binding Library.SelectedSong}"
                                    Background="#020617"
                                    BorderBrush="#334155"
                                    Foreground="#E0F2FE">

                                <ListBox.ItemTemplate>

                                    <DataTemplate>

                                        <StackPanel>

                                            <TextBlock
                                                    Text="{Binding DisplayName}"
                                                    FontWeight="Bold"/>

                                            <TextBlock
                                                    Text="{Binding Status}"
                                                    FontSize="10"
                                                    Foreground="#94A3B8"/>

                                        </StackPanel>

                                    </DataTemplate>

                                </ListBox.ItemTemplate>

                            </ListBox>

                        </TabItem>

                        <TabItem Header="Favorites">

                            <ListBox
                                    ItemsSource="{Binding Library.FavoriteSongs}"
                                    SelectedItem="{Binding Library.SelectedSong}"
                                    Background="#020617"
                                    BorderBrush="#334155"
                                    Foreground="#E0F2FE">

                                <ListBox.ItemTemplate>

                                    <DataTemplate>

                                        <StackPanel>

                                            <TextBlock
                                                    Text="{Binding DisplayName}"
                                                    FontWeight="Bold"/>

                                            <TextBlock
                                                    Text="{Binding Status}"
                                                    FontSize="10"
                                                    Foreground="#94A3B8"/>

                                        </StackPanel>

                                    </DataTemplate>

                                </ListBox.ItemTemplate>

                            </ListBox>

                        </TabItem>

                    </TabControl>

                    <Image Grid.Row="2"
                               Height="90"
                               Margin="0,6,0,6"
                               Stretch="Uniform"
                               Source="{Binding Library.SelectedSong.CoverPath}" Grid.ColumnSpan="2" />

                    <StackPanel Grid.Row="3"
                                    Orientation="Vertical"
                                    Margin="0,4,0,0" Grid.ColumnSpan="2">

                        <TextBlock
                                Text="{Binding Library.TotalSongs, StringFormat=Totali: {0}}"
                                Foreground="#7DD3FC"
                                FontSize="10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <TextBlock Text="{Binding Library.KarSongs, StringFormat=KAR: {0}}" Foreground="#60A5FA" FontSize="10" Margin="0,0,8,0"/>
                            <TextBlock Text="{Binding Library.MidSongs, StringFormat=MID: {0}}" Foreground="#34D399" FontSize="10"/>
                        </StackPanel>

                        <TextBlock Text="{Binding Library.ReadySongs, StringFormat=Pronte: {0}}" Foreground="#22C55E" FontSize="10"/>

                        <TextBlock Text="{Binding Library.FavoriteSongs, StringFormat=Preferite: {0}}" Foreground="#FACC15" FontSize="10"/>

                        <TextBlock Text="{Binding Library.MissingSongs, StringFormat=Mancanti: {0}}" Foreground="#EF4444" FontSize="10"/>

                    </StackPanel>

                    <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Left" Margin="35,6,0,0" Grid.ColumnSpan="2">
                        <Button Content="PREV" Command="{Binding PreviousSongCommand}" Width="58" Height="24" Margin="2"/>
                        <Button Content="★" Width="40" Height="28" Margin="4" Command="{Binding ToggleFavoriteCommand}" />
                        <Button Content="NEXT" Command="{Binding NextSongCommand}" Width="58" Height="24" Margin="2"/>
                    </StackPanel>
                </Grid>
            </controls:FloatingPanel>

            <!-- New playlist panel (Explorer) -->
                        <controls:FloatingPanel Title="LIBRERIA" Width="520" Height="500" Canvas.Left="18" Canvas.Top="500" MinWidth="420" MinHeight="135">
                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.ColumnSpan="3">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,6">
                                        <Button Content="📂 Seleziona cartella" Command="{Binding SelectLibraryFolderCommand}" Width="140" Height="24" Margin="0,0,8,0"/>
                                        <Button Content="🔄 Aggiorna" Command="{Binding RefreshLibraryCommand}" Width="90" Height="24"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Row="1" Grid.Column="0" Background="#020617" BorderBrush="#334155" CornerRadius="4" Padding="6">
                                    <ListBox ItemsSource="{Binding Library.Songs}" SelectedItem="{Binding Library.SelectedSong}" DisplayMemberPath="Title" Background="#020617" BorderBrush="#334155" Foreground="#E0F2FE"/>
                                </Border>

                                <GridSplitter Grid.Row="1" Grid.Column="1" Width="6" HorizontalAlignment="Stretch" Background="#0F172A"/>

                                <Grid Grid.Row="1" Grid.Column="2">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="140"/>
                                    </Grid.RowDefinitions>
                                    <TreeView x:Name="FolderTree" Background="#020617" BorderBrush="#334155" Foreground="#E0F2FE"/>
                                    <Border Grid.Row="1" Background="#020617" BorderBrush="#334155" Margin="0,6,0,0" CornerRadius="4">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="*"/>
                                            </Grid.RowDefinitions>
                                            <StackPanel Orientation="Horizontal" Grid.Row="0" HorizontalAlignment="Right" Margin="4">
                                                <Button Content="Aggiungi" Width="80" Height="24" Margin="4"/>
                                                <Button Content="Aggiungi tutti" Width="110" Height="24" Margin="4"/>
                                            </StackPanel>
                                            <ListBox x:Name="FolderFilesList" Grid.Row="1" Background="#020617" BorderBrush="#334155" Foreground="#E0F2FE"/>
                                        </Grid>
                                    </Border>
                                </Grid>

                            </Grid>
                        </controls:FloatingPanel>

                        <Border Height="24" Width="820" Canvas.Left="280" Canvas.Top="680" Background="#0F172A" BorderBrush="#7DD3FC" BorderThickness="1" CornerRadius="3">
                <DockPanel LastChildFill="True" Margin="8,0">
                    <TextBlock DockPanel.Dock="Left" Text="{Binding Status}" Foreground="#BAE6FD" FontSize="11" VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding PlayerVM.Note}" Foreground="#22C55E" FontSize="11" VerticalAlignment="Center"/>
                </DockPanel>
            </Border>

            <Grid Width="1" Height="1" Opacity="0" IsHitTestVisible="False" Canvas.Left="0" Canvas.Top="0">
                <MediaElement x:Name="VideoPlayer" LoadedBehavior="Manual" UnloadedBehavior="Stop" Stretch="Uniform"/>
                <wv2:WebView2 x:Name="YouTubePlayer" Visibility="Collapsed"/>
                <StackPanel x:Name="VideoPlaceholder"/>
                <ToggleButton IsChecked="{Binding PlayerVM.IsYouTube}"/>
            </Grid>
        </Canvas>
    </Grid>
</Window>
