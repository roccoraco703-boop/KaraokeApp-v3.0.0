<Window x:Class="KaraokeApp.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Width="600" Height="300"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True">

    <Border Background="#0F172A" CornerRadius="12" Padding="20" Opacity="0.95">
        <Grid>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Vertical">
                <StackPanel.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="Margin" Value="0,4" />
                        <Setter Property="HorizontalAlignment" Value="Center" />
                    </Style>
                </StackPanel.Resources>
                <TextBlock FontSize="28" Foreground="#38BDF8" FontWeight="Bold">KaraokeApp V3</TextBlock>
                <TextBlock FontSize="14" Foreground="#F8FAFC">Lyrics Engine 2.0</TextBlock>
                <TextBlock FontSize="14" Foreground="#F8FAFC">Pitch Tracking</TextBlock>
                <TextBlock FontSize="14" Foreground="#F8FAFC">VanBasco Edition</TextBlock>
            </StackPanel>
        </Grid>
    </Border>
</Window>